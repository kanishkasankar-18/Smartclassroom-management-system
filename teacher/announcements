<?php
require_once '../config.php';
require_once '../includes/auth.php';
requireRole('teacher');

$pageTitle = 'Announcements';
$teacherId = $_SESSION['user_id'];
$success = '';

$classes = $pdo->prepare("SELECT id, name, section FROM classes WHERE teacher_id = ?");
$classes->execute([$teacherId]);
$classes = $classes->fetchAll();

// Add announcement
if ($_SERVER['REQUEST_METHOD'] === 'POST' && $_POST['action'] === 'add') {
    $pdo->prepare("INSERT INTO announcements (title, message, teacher_id, class_id) VALUES (?,?,?,?)")
        ->execute([trim($_POST['title']), trim($_POST['message']), $teacherId, (int)$_POST['class_id']]);
    $success = 'Announcement posted successfully.';
}

// Delete announcement
if (isset($_GET['delete'])) {
    $pdo->prepare("DELETE FROM announcements WHERE id = ? AND teacher_id = ?")->execute([$_GET['delete'], $teacherId]);
    $success = 'Announcement deleted.';
}

$announcements = $pdo->prepare("SELECT a.*, c.name AS class_name FROM announcements a
    JOIN classes c ON c.id = a.class_id
    WHERE a.teacher_id = ? ORDER BY a.created_at DESC");
$announcements->execute([$teacherId]);
$announcements = $announcements->fetchAll();

include '../includes/header.php';
?>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="section-title"><i class="bi bi-megaphone me-2 text-warning"></i>Announcements</h4>
    <button class="btn btn-warning text-dark" data-bs-toggle="modal" data-bs-target="#addAnnouncementModal">
        <i class="bi bi-plus-circle me-2"></i>Post Announcement
    </button>
</div>

<?php if ($success): ?>
<div class="alert alert-success alert-dismissible fade show"><?= $success ?>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
<?php endif; ?>

<?php if (!empty($announcements)): ?>
    <?php foreach ($announcements as $a): ?>
    <div class="announcement-card">
        <div class="d-flex justify-content-between align-items-start">
            <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <h5 class="fw-bold mb-0"><?= htmlspecialchars($a['title']) ?></h5>
                    <span class="badge bg-warning text-dark"><?= htmlspecialchars($a['class_name']) ?></span>
                </div>
                <p class="text-dark mb-2"><?= nl2br(htmlspecialchars($a['message'])) ?></p>
                <small class="text-muted">
                    <i class="bi bi-clock me-1"></i><?= date('d M Y, h:i A', strtotime($a['created_at'])) ?>
                </small>
            </div>
            <a href="announcements.php?delete=<?= $a['id'] ?>"
               class="btn btn-sm btn-outline-danger ms-3"
               onclick="return confirm('Delete this announcement?')">
                <i class="bi bi-trash"></i>
            </a>
        </div>
    </div>
    <?php endforeach; ?>
<?php else: ?>
<div class="text-center py-5 text-muted">
    <i class="bi bi-megaphone fs-1"></i>
    <p class="mt-2">No announcements posted yet.</p>
</div>
<?php endif; ?>

